# Database
DATABASE_URL=postgresql+asyncpg://blogadmin:changeme@localhost:5432/blogplatform

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
DEBUG=true
# ALLOWED_ORIGINS accepts plain CSV (recommended) OR a JSON array
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
